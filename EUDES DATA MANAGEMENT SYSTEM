    function setupDashboardTabs() {
        const allowed = ROLE_TABS[session.role] || [];
        document.querySelectorAll('.tab').forEach(tab => {
            tab.style.display = allowed.includes(tab.getAttribute('data-tab')) ? '' : 'none';
        });
