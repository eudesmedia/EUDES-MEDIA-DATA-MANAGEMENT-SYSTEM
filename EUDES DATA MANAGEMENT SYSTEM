    function getGrade(score) { if (score>=90) return 'D1'; if (score>=80) return 'D2'; if (score>=70) return 'C3'; if (score>=60) return 'C4'; if (score>=50) return 'C5'; if (score>=40) return 'C6'; if (score>=35) return 'P7'; if (score>=30) return 'P8'; return 'F9'; }
    function formatCurrency(amt) { return new Intl.NumberFormat('en-UG', { style: 'currency', currency: 'UGX' }).format(amt||0); }

    function updateUI() {
        const total = students.length, absent = students.filter(s => s.is_absent).length;
        document.getElementById('stat_total').innerText = total;
        document.getElementById('stat_present').innerText = total - absent;
        document.getElementById('stat_absent').innerText = absent;
        document.getElementById('stat_pending').innerText = reportCards.filter(rc => rc.status === 'pending').length;

        const activeTab = document.querySelector('.tab.active')?.getAttribute('data-tab') || 'abs';
        switch(activeTab) {
            case 'abs': renderAbsentees(); break;
            case 'rec': renderRecords(); break;
            case 'adm': renderAdmission(); break;
            case 'roll': renderRollCall(); break;
            case 'marks': renderMarksPage(); break;
            case 'reports': renderReportsPage(); break;
            case 'fees': renderFees(); break;
            case 'promote': renderPromotion(); break;
            case 'subjects': renderSubjects(); break;
            case 'idcards': renderIdCards(); break;
        }
    }

    function showTab(tabId) {
        document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        const viewEl = document.getElementById(`view-${tabId}`);
        if (viewEl) viewEl.classList.remove('hidden');
        const tabEl = document.querySelector(`.tab[data-tab="${tabId}"]`);
        if (tabEl) tabEl.classList.add('active');
        updateUI();
    }
    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', () => showTab(tab.getAttribute('data-tab')));
    });

    // ------- RENDER FUNCTIONS -------
    function renderAbsentees() {
        let list = students.filter(s => s.is_absent);
        let html = `<div class="form-group"><label>Class</label><select id="absClassFilter" onchange="renderAbsentees()"><option value="all">All Classes</option>${['Baby','Middle','Top','P.1','P.2','P.3','P.4','P.5','P.6','P.7'].map(c=>`<option>${c}</option>`).join('')}</select></div>`;
        if (document.getElementById('absClassFilter')?.value!=='all') list = list.filter(s => s.class === document.getElementById('absClassFilter')?.value);
        html += list.map(s => `<div class="card absent-card"><div class="student-photo">${s.name.charAt(0)}</div><div><b>${s.name}</b><br>${s.class} | ${s.parent_contact||'-'}</div><button class="btn-sm" onclick="notifyParent('${s.id}','whatsapp')">📱</button><button class="btn-sm" onclick="notifyParent('${s.id}','email')">📧</button></div>`).join('');
        if (!list.length) html += '<div class="card">No absent pupils.</div>';
        document.getElementById('view-abs').innerHTML = html;
    }

    function renderRecords() {
        const search = document.getElementById('searchRecords')?.value?.toLowerCase() || '';
