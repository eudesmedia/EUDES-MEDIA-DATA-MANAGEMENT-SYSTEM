    async function loadAllData() {
        document.getElementById('db_status').innerHTML = '● LOADING...';
        document.getElementById('systemMessage').innerHTML = '';
        students = await safeFetch('students', { sch_id: session.schId });
        subjects = await safeFetch('subjects', { sch_id: session.schId });
        terms = await safeFetch('terms', { sch_id: session.schId });
        marksData = await safeFetch('marks', { sch_id: session.schId });
        reportCards = await safeFetch('report_cards', { sch_id: session.schId });
        attendanceRecords = await safeFetch('attendance', { sch_id: session.schId });
        feePayments = await safeFetch('fee_payments', { sch_id: session.schId });

        document.getElementById('db_status').innerHTML = `● LIVE (${students.length} students)`;
