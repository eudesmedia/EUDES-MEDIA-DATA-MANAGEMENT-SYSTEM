    // Helper: hash password
    async function hashPassword(pw) {
        const data = new TextEncoder().encode(pw);
        const hash = await crypto.subtle.digest('SHA-256', data);
        return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2,'0')).join('');
    }

    // Safe Supabase fetch (never throws – shows error on page)
    async function safeFetch(table, filter = {}) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [k,v] of Object.entries(filter)) url += `${k}=eq.${encodeURIComponent(v)}&`;
        url = url.replace(/&$/, '');
        try {
            const res = await fetch(url, { headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` } });
            if (!res.ok) throw new Error(`HTTP ${res.status}: ${await res.text()}`);
            return await res.json();
        } catch (e) {
            console.error(`Fetch error (${table}):`, e);
            document.getElementById('systemMessage').innerHTML +=
                `<div class="error-box">⚠️ Failed to load ${table}: ${e.message}</div>`;
            return [];
        }
    }

    async function safeInsert(table, body) {
        try {
            const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}`, {
                method: 'POST',
                headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            if (!res.ok) throw new Error(`Insert error: ${await res.text()}`);
        } catch (e) {
            console.error(e);
            document.getElementById('systemMessage').innerHTML += `<div class="error-box">❌ Save to ${table} failed: ${e.message}</div>`;
        }
    }

    async function safeUpdate(table, filter, body) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [k,v] of Object.entries(filter)) url += `${k}=eq.${encodeURIComponent(v)}&`;
        url = url.replace(/&$/, '');
        try {
            const res = await fetch(url, {
                method: 'PATCH',
                headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            if (!res.ok) throw new Error(`Update error: ${await res.text()}`);
        } catch (e) {
            console.error(e);
            document.getElementById('systemMessage').innerHTML += `<div class="error-box">❌ Update ${table} failed: ${e.message}</div>`;
        }
    }

    async function safeDelete(table, filter) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [k,v] of Object.entries(filter)) url += `${k}=eq.${encodeURIComponent(v)}&`;
        url = url.replace(/&$/, '');
        try {
            const res = await fetch(url, {
                method: 'DELETE',
                headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
            });
            if (!res.ok) throw new Error(`Delete error: ${await res.text()}`);
        } catch (e) {
            console.error(e);
            document.getElementById('systemMessage').innerHTML += `<div class="error-box">❌ Delete from ${table} failed: ${e.message}</div>`;
        }
    }

    // Auto-heal passwords: always ensure the real hash is in the DB
    async function ensureDemoUsers() {
        const users = await safeFetch('school_users', { sch_id: 'PM001' });
        const realAdminHash = await hashPassword('PM001@admin2024');
        const realTeacherHash = await hashPassword('PM001@teacher2024');
        const realFinanceHash = await hashPassword('PM001@finance2024');

        // If no users, insert them
        if (users.length === 0) {
            await safeInsert('school_users', [
                { sch_id:'PM001', email:'pm001.admin@eudesacademy', password_hash:realAdminHash, role:'admin', is_active:true },
                { sch_id:'PM001', email:'pm001.teacher@eudesacademy', password_hash:realTeacherHash, role:'teacher', is_active:true },
                { sch_id:'PM001', email:'pm001.finance@eudesacademy', password_hash:realFinanceHash, role:'finance', is_active:true }
            ]);
            return;
        }

        // Fix any user whose hash is not the real one
        for (const u of users) {
            let realHash;
            if (u.email.includes('admin')) realHash = realAdminHash;
            else if (u.email.includes('teacher')) realHash = realTeacherHash;
            else if (u.email.includes('finance')) realHash = realFinanceHash;
            else continue;

            if (u.password_hash !== realHash) {
                await safeUpdate('school_users', { email: u.email }, { password_hash: realHash });
            }
        }
    }

    async function login(email, password) {
        const hashed = await hashPassword(password);
        const res = await fetch(`${SUPABASE_URL}/rest/v1/school_users?email=eq.${encodeURIComponent(email)}&select=*,schools!inner(*)`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
        });
        if (!res.ok) throw new Error('Network error');
        const users = await res.json();
        if (users.length === 0) throw new Error('❌ Invalid email');
        const user = users[0];
        if (user.password_hash !== hashed) throw new Error('❌ Wrong password');
        if (!user.is_active) throw new Error('🚫 Account deactivated');
        if (!user.schools || !user.schools.is_active) throw new Error('⚠️ School subscription expired');
        return {
            userId: user.id, schId: user.sch_id, schoolName: user.schools.school_name,
            role: user.role, email: user.email, location: user.schools.location,
            contact: user.schools.contact_numbers, whatsapp: user.schools.whatsapp_number,
            shortCode: user.schools.short_code
        };
    }

