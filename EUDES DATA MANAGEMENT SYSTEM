<script>
    /*************************************************************
     *  SUPABASE CONFIG
     *************************************************************/
    const SUPABASE_URL = 'https://kjftrwuucjdnhfwesrup.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtqZnRyd3V1Y2pkbmhmd2VzcnVwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3Njc0OTksImV4cCI6MjA4NzM0MzQ5OX0.YAIdcBo2MXs86CrunR2CBM4Uh6RjNbGxIG-E260NfCM';

    /*************************************************************
     *  GLOBAL STATE
     *************************************************************/
    let session = null;
    let students = [], marksData = [], reportCards = [], subjects = [],
        attendanceRecords = [], terms = [], feePayments = [];
    let editingStudentId = null;
    let SCHOOL_UUID = null;

    const ROLE_TABS = {
        admin: ['abs','rec','adm','roll','marks','reports','fees','promote','subjects','idcards'],
        teacher: ['abs','roll','marks'],
        finance: ['abs','adm','fees']
    };

    /*************************************************************
     *  SUPABASE HELPERS
     *************************************************************/
    async function restFetch(table, filter = {}) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [key, val] of Object.entries(filter)) url += `${key}=eq.${encodeURIComponent(val)}&`;
        if (url.endsWith('&')) url = url.slice(0, -1);
        const res = await fetch(url, { headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` } });
        if (!res.ok) throw new Error(await res.text());
        return await res.json();
    }

    async function restInsert(table, body) {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}`, {
            method: 'POST',
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}`, 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!res.ok) throw new Error(await res.text());
        return res;
    }

    async function restUpdate(table, filter, body) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [key, val] of Object.entries(filter)) url += `${key}=eq.${encodeURIComponent(val)}&`;
        if (url.endsWith('&')) url = url.slice(0, -1);
        const res = await fetch(url, {
            method: 'PATCH',
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}`, 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!res.ok) throw new Error(await res.text());
        return res;
    }

    async function restDelete(table, filter) {
        let url = `${SUPABASE_URL}/rest/v1/${table}?`;
        for (const [key, val] of Object.entries(filter)) url += `${key}=eq.${encodeURIComponent(val)}&`;
        if (url.endsWith('&')) url = url.slice(0, -1);
        const res = await fetch(url, {
            method: 'DELETE',
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
        });
        if (!res.ok) throw new Error(await res.text());
        return res;
    }

    /*************************************************************
     *  AUTH & SESSION
     *************************************************************/
    async function hashPassword(pw) {
        const encoder = new TextEncoder();
        const data = encoder.encode(pw);
        const hashBuffer = await crypto.subtle.digest('SHA-256', data);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    }

    async function ensureDemoUsers() {
        const users = await restFetch('school_users', { sch_id: 'PM001' });
        if (users.length === 0 || users[0].password_hash.startsWith('PLACEHOLDER')) {
            const adminHash = await hashPassword('PM001@admin2024');
            const teacherHash = await hashPassword('PM001@teacher2024');
            const financeHash = await hashPassword('PM001@finance2024');
            if (users.length === 0) {
                await restInsert('school_users', [
                    { sch_id:'PM001', email:'pm001.admin@eudesacademy', password_hash:adminHash, role:'admin', is_active:true },
                    { sch_id:'PM001', email:'pm001.teacher@eudesacademy', password_hash:teacherHash, role:'teacher', is_active:true },
                    { sch_id:'PM001', email:'pm001.finance@eudesacademy', password_hash:financeHash, role:'finance', is_active:true }
                ]);
            } else {
                for (const u of users) {
                    if (u.email.includes('admin')) await restUpdate('school_users', { email: u.email }, { password_hash: adminHash });
                    if (u.email.includes('teacher')) await restUpdate('school_users', { email: u.email }, { password_hash: teacherHash });
                    if (u.email.includes('finance')) await restUpdate('school_users', { email: u.email }, { password_hash: financeHash });
                }
            }
        }
    }

    async function login(email, password) {
        const hashed = await hashPassword(password);
        const res = await fetch(`${SUPABASE_URL}/rest/v1/school_users?email=eq.${encodeURIComponent(email)}&select=*,schools!inner(*)`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
        });
        if (!res.ok) throw new Error('Network error');
        const users = await res.json();
        if (users.length === 0) throw new Error('❌ Invalid email');
        const user = users[0];
        if (user.password_hash !== hashed) throw new Error('❌ Wrong password');
        if (!user.is_active) throw new Error('🚫 Account deactivated');
        if (!user.schools || !user.schools.is_active) throw new Error('⚠️ School subscription expired');

        return {
            userId: user.id,
            schId: user.sch_id,
            schoolName: user.schools.school_name,
            role: user.role,
            email: user.email,
            location: user.schools.location,
            contact: user.schools.contact_numbers,
            whatsapp: user.schools.whatsapp_number,
            shortCode: user.schools.short_code
        };
    }

    function quickLogin(email, pass) {
        document.getElementById('email').value = email;
        document.getElementById('password').value = pass;
        document.getElementById('loginForm').dispatchEvent(new Event('submit'));
    }

    function showLoginScreen() {
        document.getElementById('login-screen').classList.remove('hidden');
        document.getElementById('dashboard-screen').classList.add('hidden');
    }

    function showDashboard() {
        document.getElementById('login-screen').classList.add('hidden');
        document.getElementById('dashboard-screen').classList.remove('hidden');
        document.getElementById('schoolNameDisplay').textContent = session.schoolName;
        setupDashboardTabs();
        loadAllData();
    }

    function logout() {
        sessionStorage.removeItem('eudes_sms_session');
        session = null;
        showLoginScreen();
    }

    /*************************************************************
     *  DASHBOARD LOGIC
     *************************************************************/
    function setupDashboardTabs() {
        const allowed = ROLE_TABS[session.role] || [];
        document.querySelectorAll('.tab').forEach(tab => {
            const tabId = tab.getAttribute('data-tab');
            tab.style.display = allowed.includes(tabId) ? '' : 'none';
        });
        if (allowed.length > 0) showTab(allowed[0]);
    }

    async function loadAllData() {
        try {
            document.getElementById('db_status').innerHTML = '● LOADING...';
            const schools = await restFetch('schools', { sch_id: session.schId });
            if (schools.length === 0) throw new Error('School not found');
            SCHOOL_UUID = schools[0].id;

            students = await restFetch('students', { sch_id: session.schId });
            subjects = await restFetch('subjects', { sch_id: session.schId }).catch(() => []);
            terms = await restFetch('terms', { sch_id: session.schId }).catch(() => []);
            marksData = await restFetch('marks', { sch_id: session.schId }).catch(() => []);
            reportCards = await restFetch('report_cards', { sch_id: session.schId }).catch(() => []);
            attendanceRecords = await restFetch('attendance', { sch_id: session.schId }).catch(() => []);
            feePayments = await restFetch('fee_payments', { sch_id: session.schId }).catch(() => []);

            document.getElementById('db_status').innerHTML = `● LIVE (${students.length} students)`;
            document.getElementById('db_status').style.color = '#2b9348';
            updateUI();
        } catch (err) {
            document.getElementById('db_status').innerHTML = '● ERROR';
            document.getElementById('errorDisplay').innerHTML = err.message;
            document.getElementById('errorDisplay').classList.remove('hidden');
        }
    }

    function getGrade(score) {
        if (score >= 90) return 'D1';
        if (score >= 80) return 'D2';
        if (score >= 70) return 'C3';
        if (score >= 60) return 'C4';
        if (score >= 50) return 'C5';
        if (score >= 40) return 'C6';
        if (score >= 35) return 'P7';
        if (score >= 30) return 'P8';
        return 'F9';
    }

    function formatCurrency(amt) {
        return new Intl.NumberFormat('en-UG', { style: 'currency', currency: 'UGX' }).format(amt || 0);
    }

    function updateUI() {
        const total = students.length;
        const absent = students.filter(s => s.is_absent).length;
        document.getElementById('stat_total').innerText = total;
        document.getElementById('stat_present').innerText = total - absent;
        document.getElementById('stat_absent').innerText = absent;
        document.getElementById('stat_pending').innerText = reportCards.filter(rc => rc.status === 'pending').length;

        const activeTab = document.querySelector('.tab.active')?.getAttribute('data-tab') || 'abs';
        switch (activeTab) {
            case 'abs': renderAbsentees(); break;
            case 'rec': renderRecords(); break;
            case 'adm': renderAdmission(); break;
            case 'roll': renderRollCall(); break;
            case 'marks': renderMarksPage(); break;
            case 'reports': renderReportsPage(); break;
            case 'fees': renderFees(); break;
            case 'promote': renderPromotion(); break;
            case 'subjects': renderSubjects(); break;
            case 'idcards': renderIdCards(); break;
        }
    }

    function showTab(tabId) {
        document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        const viewEl = document.getElementById(`view-${tabId}`);
        if (viewEl) viewEl.classList.remove('hidden');
        const tabEl = document.querySelector(`.tab[data-tab="${tabId}"]`);
        if (tabEl) tabEl.classList.add('active');
        updateUI();
    }

    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', () => showTab(tab.getAttribute('data-tab')));
    });

    // ---------- VIEW RENDERERS ----------
    function renderAbsentees() {
        let list = students.filter(s => s.is_absent);
        let html = `<div class="form-group"><label>Class</label><select id="absClassFilter" onchange="renderAbsentees()">
            <option value="all">All Classes</option>
            ${['Baby','Middle','Top','P.1','P.2','P.3','P.4','P.5','P.6','P.7'].map(c => `<option value="${c}">${c}</option>`).join('')}
        </select></div>`;
        const filterClass = document.getElementById('absClassFilter')?.value || 'all';
        if (filterClass !== 'all') list = list.filter(s => s.class === filterClass);
        html += list.map(s => `
            <div class="card absent-card">
                <div class="student-photo">${s.name.charAt(0)}</div>
                <div><b>${s.name}</b><br>${s.class} | ${s.parent_contact || '-'}</div>
                <button class="btn-sm" onclick="notifyParent('${s.id}', 'whatsapp')">📱 WhatsApp</button>
                <button class="btn-sm" onclick="notifyParent('${s.id}', 'email')">📧 Email</button>
            </div>`).join('');
        if (list.length === 0) html += '<div class="card">No absent pupils.</div>';
        document.getElementById('view-abs').innerHTML = html;
    }

    function renderRecords() {
        let search = document.getElementById('searchRecords')?.value?.toLowerCase() || '';
        let filtered = students.filter(s => s.name.toLowerCase().includes(search) || (s.lin && s.lin.toLowerCase().includes(search)));
        let html = `<input id="searchRecords" placeholder="Search by name or LIN..." oninput="renderRecords()" style="width:100%; margin-bottom:15px; padding:12px;">`;
        html += filtered.map(s => `
            <div class="card ${s.is_absent ? 'absent-card' : ''}">
                <div class="student-photo">${s.name.charAt(0)}</div>
                <div><b>${s.name}</b><br>LIN: ${s.lin || 'Pending'} | ${s.class}</div>
                <div>
                    <button class="btn-sm" onclick="editStudent('${s.id}')" ${session.role !== 'admin' ? 'disabled' : ''}>Edit</button>
                    <button class="btn-sm btn-del" onclick="deleteStudent('${s.id}')" ${session.role !== 'admin' ? 'disabled' : ''}>Delete</button>
                </div>
            </div>`).join('');
        document.getElementById('view-rec').innerHTML = html;
    }

    window.editStudent = (id) => {
        let s = students.find(x => x.id == id);
        if (!s) return;
        editingStudentId = id;
        document.getElementById('reg_name').value = s.name;
        document.getElementById('reg_class').value = s.class;
        document.getElementById('reg_contact').value = s.parent_contact || '';
        document.getElementById('reg_photo').value = s.photo_url || '';
        document.getElementById('reg_location').value = s.location || '';
        document.getElementById('reg_health').value = s.health_status || '';
        document.getElementById('reg_fees').value = s.total_fees;
        document.getElementById('form_title').innerText = 'Edit Student';
        document.getElementById('saveBtn').innerText = 'UPDATE';
        document.getElementById('cancelBtn').classList.remove('hidden');
        showTab('adm');
    };

    window.deleteStudent = async (id) => {
        if (confirm('Delete permanently?')) {
            await restDelete('students', { id });
            loadAllData();
        }
    };

    function renderAdmission() {
        document.getElementById('view-adm').innerHTML = `
            <div class="form-group">
                <h3 id="form_title">Admission</h3>
                <div class="photo-preview" id="photoPreview" style="width:100px;height:100px;border-radius:50%;background:#eee;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">📷</div>
                <input type="file" accept="image/*" capture="environment" onchange="handlePhotoUpload(event)">
                <label>Photo URL (or upload)</label><input id="reg_photo">
                <label>Full Name</label><input id="reg_name">
                <label>Class</label><select id="reg_class">${['Baby','Middle','Top','P.1','P.2','P.3','P.4','P.5','P.6','P.7'].map(c => `<option>${c}</option>`).join('')}</select>
                <label>Parent Contact</label><input id="reg_contact">
                <label>Location</label><input id="reg_location">
                <label>Health Status</label><input id="reg_health">
                <label>Total Fees (UGX)</label><input id="reg_fees" type="number" value="0">
                <button class="btn-main" id="saveBtn" onclick="saveStudent()">SAVE</button>
                <button class="btn-main hidden" id="cancelBtn" onclick="cancelEdit()">CANCEL</button>
            </div>`;
        if (editingStudentId) {
            const s = students.find(st => st.id == editingStudentId);
            if (s) {
                document.getElementById('reg_name').value = s.name;
                document.getElementById('reg_class').value = s.class;
                document.getElementById('reg_contact').value = s.parent_contact || '';
                document.getElementById('reg_photo').value = s.photo_url || '';
                document.getElementById('reg_location').value = s.location || '';
                document.getElementById('reg_health').value = s.health_status || '';
                document.getElementById('reg_fees').value = s.total_fees;
                document.getElementById('form_title').innerText = 'Edit Student';
                document.getElementById('saveBtn').innerText = 'UPDATE';
                document.getElementById('cancelBtn').classList.remove('hidden');
            }
        }
    }

    function handlePhotoUpload(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = ev => {
                document.getElementById('reg_photo').value = ev.target.result;
                document.getElementById('photoPreview').innerHTML = `<img src="${ev.target.result}" style="width:100%;height:100%;object-fit:cover;">`;
            };
            reader.readAsDataURL(file);
        }
    }

    window.saveStudent = async () => {
        const name = document.getElementById('reg_name').value.trim();
        if (!name) return alert('Name required');
        const data = {
            sch_id: session.schId,
            name,
            class: document.getElementById('reg_class').value,
            parent_contact: document.getElementById('reg_contact').value,
            photo_url: document.getElementById('reg_photo').value,
            location: document.getElementById('reg_location').value,
            health_status: document.getElementById('reg_health').value,
            total_fees: parseFloat(document.getElementById('reg_fees').value) || 0,
            fees_paid: 0,
            is_absent: false,
            lin: editingStudentId ? (students.find(s => s.id == editingStudentId)?.lin) : `${session.schId}-${name.charAt(0)}${Math.floor(Math.random() * 9000 + 1000)}`
        };
        if (editingStudentId) {
            await restUpdate('students', { id: editingStudentId }, data);
        } else {
            await restInsert('students', [data]);
        }
        cancelEdit();
        loadAllData();
        showTab('rec');
    };

    window.cancelEdit = () => {
        editingStudentId = null;
        document.getElementById('form_title').innerText = 'Admission';
        document.getElementById('saveBtn').innerText = 'SAVE';
        document.getElementById('cancelBtn').classList.add('hidden');
        ['reg_name','reg_photo','reg_contact','reg_location','reg_health'].forEach(id => document.getElementById(id).value = '');
        document.getElementById('reg_fees').value = '0';
        document.getElementById('photoPreview').innerHTML = '📷';
    };

    function renderRollCall() {
        let html = '';
        students.forEach(s => {
            html += `<div class="card"><div><b>${s.name}</b><br>${s.class}</div>
                     <button class="btn-main" style="background:${s.is_absent ? '#d90429' : '#2b9348'};width:auto;padding:8px 16px;" onclick="toggleAbsence('${s.id}')">${s.is_absent ? 'ABSENT' : 'PRESENT'}</button></div>`;
        });
        html += `<button class="btn-main" onclick="saveAttendanceHistory()">Save Today's Record</button>`;
        document.getElementById('view-roll').innerHTML = html;
    }

    window.toggleAbsence = async (id) => {
        const s = students.find(x => x.id == id);
        if (s) {
            await restUpdate('students', { id }, { is_absent: !s.is_absent });
            loadAllData();
        }
    };

    window.saveAttendanceHistory = async () => {
        const today = new Date().toISOString().slice(0, 10);
        for (const s of students) {
            await restInsert('attendance', { sch_id: session.schId, student_id: s.id, date: today, status: s.is_absent ? 'absent' : 'present' });
        }
        alert('Attendance recorded');
    };

    function renderMarksPage() {
        const classes = [...new Set(students.map(s => s.class))];
        let html = `
            <div class="form-group">
                <label>Select Class</label>
                <select id="marksClassSelect" onchange="loadStudentsForMarks()">
                    <option value="">-- Choose Class --</option>
                    ${classes.map(c => `<option>${c}</option>`).join('')}
                </select>
                <div id="marksStudentArea"></div>
            </div>`;
        document.getElementById('view-marks').innerHTML = html;
    }

    async function loadStudentsForMarks() {
        const cls = document.getElementById('marksClassSelect').value;
        if (!cls) return;
        const classStudents = students.filter(s => s.class === cls);
        let yearOptions = '';
        for (let y = new Date().getFullYear() - 1; y <= new Date().getFullYear() + 2; y++) yearOptions += `<option value="${y}">${y}</option>`;
        let html = `
            <label>Year</label><select id="marksYearSelect">${yearOptions}</select>
            <label>Term Number</label><select id="marksTermNumberSelect">
                <option value="1">Term 1</option><option value="2">Term 2</option><option value="3">Term 3</option></select>
            <label>Exam Type</label><select id="marksExamSelect">
                <option>Beginning of Term</option><option>Mid Term</option><option selected>End of Term</option></select>
            <label>Student</label>
            <select id="marksStudentSelect" onchange="loadMarksForStudent()">
                <option value="">-- Choose Student --</option>
                ${classStudents.map(s => `<option value="${s.id}">${s.name} (${s.lin})</option>`).join('')}
            </select>
            <div id="marksEntryArea"></div>`;
        document.getElementById('marksStudentArea').innerHTML = html;
    }

    async function loadMarksForStudent() {
        const studentId = document.getElementById('marksStudentSelect').value;
        const year = document.getElementById('marksYearSelect').value;
        const termNumber = document.getElementById('marksTermNumberSelect').value;
        const examType = document.getElementById('marksExamSelect').value;
        if (!studentId || !year) return;

        const termName = `Term ${termNumber} ${year}`;
        let term = terms.find(t => t.name === termName);
        if (!term) {
            await restInsert('terms', [{
                sch_id: session.schId,
                name: termName,
                year: parseInt(year),
                term_number: parseInt(termNumber),
                start_date: `${year}-01-01`,
                end_date: `${year}-12-31`,
                is_active: true
            }]);
            terms = await restFetch('terms', { sch_id: session.schId });
            term = terms.find(t => t.name === termName);
        }
        const termId = term.id;

        const existingMarks = marksData.filter(m => m.student_id == studentId && m.term_id === termId && m.exam_type === examType);
        const map = {};
        existingMarks.forEach(m => map[m.subject_id] = m.score);

        let html = `<div class="form-group"><h4>Marks for ${students.find(s => s.id == studentId)?.name} (${examType})</h4>`;
        subjects.forEach(sub => {
            const score = map[sub.id] || '';
            html += `
                <div class="subject-row">
                    <label>${sub.name}</label>
                    <input type="number" id="mark_${sub.id}" value="${score}" min="0" max="100" onchange="updateSingleGrade('${sub.id}')">
                    <span id="grade_${sub.id}">${score ? getGrade(parseFloat(score)) : ''}</span>
                </div>`;
        });
        html += `<button class="btn-main" onclick="saveAllMarksForStudent('${studentId}', '${termId}', '${examType}')">Save All Marks</button></div>`;
        document.getElementById('marksEntryArea').innerHTML = html;
    }

    window.updateSingleGrade = (subId) => {
        const score = parseFloat(document.getElementById(`mark_${subId}`).value);
        document.getElementById(`grade_${subId}`).innerHTML = isNaN(score) ? '' : getGrade(score);
    };

    window.saveAllMarksForStudent = async (studentId, termId, examType) => {
        for (const sub of subjects) {
            const el = document.getElementById(`mark_${sub.id}`);
            if (el && el.value !== '') {
                const score = parseFloat(el.value);
                await restDelete('marks', { student_id: studentId, term_id: termId, subject_id: sub.id, exam_type: examType });
                await restInsert('marks', [{
                    sch_id: session.schId,
                    student_id: studentId,
                    term_id: termId,
                    subject_id: sub.id,
                    exam_type: examType,
                    score,
                    grade: getGrade(score)
                }]);
            }
        }
        const endMarks = marksData.filter(m => m.student_id === studentId && m.exam_type === 'End of Term');
        const avg = endMarks.length ? endMarks.reduce((a, b) => a + b.score, 0) / endMarks.length : 0;
        const total = endMarks.reduce((a, b) => a + b.score, 0);
        const rc = reportCards.find(r => r.student_id === studentId && r.term_id === termId);
        if (rc) {
            await restUpdate('report_cards', { id: rc.id }, { total_score: total, average_score: avg, status: 'pending' });
        } else {
            await restInsert('report_cards', [{
                sch_id: session.schId,
                student_id: studentId,
                term_id: termId,
                total_score: total,
                average_score: avg,
                status: 'pending'
            }]);
        }
        alert('Marks saved');
        await loadAllData();
        await loadMarksForStudent();
    };

    function renderReportsPage() {
        let html = `<div class="form-group"><h3>Report Cards</h3>`;
        students.forEach(s => {
            const rc = reportCards.find(r => r.student_id === s.id);
            const status = rc ? rc.status : 'pending';
            const avg = rc ? rc.average_score : 0;
            html += `<div class="card">
                <div><b>${s.name}</b><br>Avg: ${avg}% | Status: <span class="badge badge-${status}">${status}</span></div>
                <div>
                    <button class="btn-sm" onclick="viewReportCard('${s.id}')">View/Print</button>
                    ${session.role === 'admin' && status === 'pending' ? `<button class="btn-sm" onclick="approveReport('${s.id}')">Approve</button>` : ''}
                    ${session.role === 'admin' && status === 'approved' ? `<button class="btn-sm" onclick="releaseReport('${s.id}')">Release</button>` : ''}
                </div>
            </div>`;
        });
        html += `</div>`;
        document.getElementById('view-reports').innerHTML = html;
    }

    window.approveReport = async (sid) => {
        const rc = reportCards.find(r => r.student_id === sid);
        if (rc) { await restUpdate('report_cards', { id: rc.id }, { status: 'approved' }); loadAllData(); }
    };
    window.releaseReport = async (sid) => {
        const rc = reportCards.find(r => r.student_id === sid);
        if (rc) { await restUpdate('report_cards', { id: rc.id }, { status: 'released' }); loadAllData(); }
    };
    window.viewReportCard = (sid) => {
        const s = students.find(st => st.id == sid);
        const win = window.open();
        win.document.write(`<h2>${session.schoolName}</h2><p>${s.name}</p><button onclick="window.print()">Print</button>`);
    };

    function renderFees() {
        const totalExp = students.reduce((sum, s) => sum + (s.total_fees || 0), 0);
        const totalCol = students.reduce((sum, s) => sum + (s.fees_paid || 0), 0);
        document.getElementById('view-fees').innerHTML = `
            <div class="form-group"><h3>Financial Summary</h3>
                <p>Expected: ${formatCurrency(totalExp)}</p>
                <p>Collected: ${formatCurrency(totalCol)}</p>
                <p>Outstanding: ${formatCurrency(totalExp - totalCol)}</p>
            </div>
            <div class="form-group"><h3>Record Payment</h3>
                <label>Student</label><select id="feeStudent">${students.map(s => `<option value="${s.id}">${s.name} (Debt: ${formatCurrency(s.total_fees - s.fees_paid)})</option>`).join('')}</select>
                <label>Amount</label><input id="feeAmount" type="number">
                <label>Method</label><select id="feeMethod"><option>cash</option><option>mobile_money</option><option>bank_transfer</option></select>
                <button class="btn-main" onclick="recordPayment()">Record Payment</button>
            </div>
            <div class="form-group"><h3>Payment History</h3>
                <div id="paymentHistory">${feePayments.slice().reverse().map(p => `<div class="card">${formatCurrency(p.amount)} - ${p.payment_method}</div>`).join('')}</div>
            </div>`;
    }

    window.recordPayment = async () => {
        const studentId = document.getElementById('feeStudent').value;
        const amount = parseFloat(document.getElementById('feeAmount').value);
        const method = document.getElementById('feeMethod').value;
        if (!studentId || !amount) return alert('Select student and amount');
        await restInsert('fee_payments', [{
            sch_id: session.schId,
            student_id: studentId,
            amount,
            payment_method: method,
            receipt_number: `RCP-${Date.now()}`
        }]);
        const s = students.find(st => st.id === studentId);
        await restUpdate('students', { id: studentId }, { fees_paid: (s.fees_paid || 0) + amount });
        loadAllData();
    };

    function renderPromotion() {
        const classes = [...new Set(students.map(s => s.class))];
        document.getElementById('view-promote').innerHTML = `
            <div class="form-group">
                <label>From Class</label><select id="promoteFrom">${classes.map(c => `<option>${c}</option>`).join('')}</select>
                <button class="btn-main" onclick="runPromotion()">Promote Eligible</button>
            </div>`;
    }

    window.runPromotion = async () => {
        const from = document.getElementById('promoteFrom').value;
        const order = ['Baby', 'Middle', 'Top', 'P.1', 'P.2', 'P.3', 'P.4', 'P.5', 'P.6', 'P.7'];
        const idx = order.indexOf(from);
        if (idx === -1 || idx === order.length - 1) return alert('Cannot promote');
        const to = order[idx + 1];
        let count = 0;
        for (const s of students.filter(s => s.class === from)) {
            const endMarks = marksData.filter(m => m.student_id === s.id && m.exam_type === 'End of Term');
            const avg = endMarks.length ? endMarks.reduce((a, b) => a + b.score, 0) / endMarks.length : 0;
            if (avg >= 45) {
                await restUpdate('students', { id: s.id }, { class: to });
                count++;
            }
        }
        alert(`${count} students promoted to ${to}`);
        loadAllData();
    };

    function renderSubjects() {
        document.getElementById('view-subjects').innerHTML = `
            <div class="form-group"><h3>Subjects</h3>
                <input id="newSubject" placeholder="New subject name"><button class="btn-main" onclick="addSubject()">Add</button>
                <div>${subjects.map(s => `<div class="card">${s.name} <button class="btn-sm btn-del" onclick="deleteSubject('${s.id}')">Del</button></div>`).join('')}</div>
            </div>`;
    }

    window.addSubject = async () => {
        const name = document.getElementById('newSubject').value.trim();
        if (!name) return;
        await restInsert('subjects', [{ sch_id: session.schId, name }]);
        loadAllData();
    };

    window.deleteSubject = async (id) => {
        await restDelete('subjects', { id });
        loadAllData();
    };

    function renderIdCards() {
        let html = `<div class="form-group"><h3>Student ID Cards</h3>`;
        students.forEach(s => {
            const vu = new Date(); vu.setFullYear(vu.getFullYear() + 1);
            html += `<div class="card">
                <div class="student-photo">${s.name.charAt(0)}</div>
                <div><b>${s.name}</b><br>LIN: ${s.lin} | ${s.class}<br>Valid: ${vu.toISOString().slice(0, 10)}</div>
                <button class="btn-sm" onclick="printIdCard('${s.id}')">Print</button>
            </div>`;
        });
        html += `</div>`;
        document.getElementById('view-idcards').innerHTML = html;
    }

    window.printIdCard = (sid) => {
        const s = students.find(st => st.id == sid);
        const win = window.open();
        win.document.write(`<h3>${session.schoolName}</h3><p>${s.name} - ${s.lin}</p><button onclick="window.print()">Print</button>`);
    };

    window.notifyParent = (sid, channel) => {
        const s = students.find(st => st.id === sid);
        if (!s) return;
        if (channel === 'whatsapp' && s.parent_whatsapp) {
            console.log(`📱 WhatsApp to ${s.parent_whatsapp}`);
            alert('WhatsApp notification sent (demo)');
        } else if (channel === 'email' && s.parent_email) {
            console.log(`📧 Email to ${s.parent_email}`);
            alert('Email notification sent (demo)');
        } else {
            alert('No contact info available');
        }
    };

    /*************************************************************
     *  CLOCKS
     *************************************************************/
    function updateClocks() {
        const now = new Date();
        const ugTime = new Date(now.toLocaleString('en-US', { timeZone: 'Africa/Kampala' }));
        const timeStr = ugTime.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', timeZone: 'Africa/Kampala' });
        document.getElementById('clock').innerHTML = timeStr;
        document.getElementById('ugandaTimeLogin').innerHTML = '🕐 ' + timeStr + ' EAT';
    }

    setInterval(updateClocks, 1000);
    updateClocks();

    /*************************************************************
     *  INITIALIZATION
     *************************************************************/
    window.addEventListener('DOMContentLoaded', async () => {
        // Restore session if exists
        const saved = sessionStorage.getItem('eudes_sms_session');
        if (saved) {
            session = JSON.parse(saved);
            showDashboard();
        } else {
            showLoginScreen();
            await ensureDemoUsers();
        }

        // Login form handler
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value.trim().toLowerCase();
            const password = document.getElementById('password').value;
            const errDiv = document.getElementById('loginError');
            errDiv.classList.remove('show');
            errDiv.textContent = '';

            if (!email || !password) {
                errDiv.textContent = '⚠️ Fill all fields';
                errDiv.classList.add('show');
                return;
            }

            const loginBtn = document.getElementById('loginBtn');
            loginBtn.disabled = true;
            loginBtn.textContent = '⏳ Logging in...';

            try {
                session = await login(email, password);
                sessionStorage.setItem('eudes_sms_session', JSON.stringify(session));
                showDashboard();
            } catch (err) {
                errDiv.textContent = err.message;
                errDiv.classList.add('show');
                loginBtn.disabled = false;
                loginBtn.textContent = '🚀 LOGIN';
            }
        });
    });
</script>
