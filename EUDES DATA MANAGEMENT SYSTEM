    function handlePhotoUpload(e) {
        const file = e.target.files[0]; if(!file) return;
        const reader = new FileReader();
        reader.onload = ev => {
            document.getElementById('reg_photo').value = ev.target.result;
            document.getElementById('photoPreview').innerHTML = `<img src="${ev.target.result}" style="width:100%;height:100%;object-fit:cover;">`;
        };
        reader.readAsDataURL(file);
    }
    window.saveStudent = async () => {
        const name = document.getElementById('reg_name').value.trim();
        if (!name) return alert('Name required');
        const data = {
            sch_id: session.schId, name, class: document.getElementById('reg_class').value,
            parent_contact: document.getElementById('reg_contact').value,
            photo_url: document.getElementById('reg_photo').value,
            total_fees: parseFloat(document.getElementById('reg_fees').value)||0,
            fees_paid: 0, is_absent: false,
            lin: editingStudentId ? (students.find(s=>s.id===editingStudentId)?.lin) : `${session.schId}-${name.charAt(0)}${Math.floor(Math.random()*9000+1000)}`
        };
        if(editingStudentId) { await safeUpdate('students',{id:editingStudentId}, data); }
        else { await safeInsert('students',[data]); }
        cancelEdit(); loadAllData(); showTab('rec');
    };
    window.cancelEdit = () => {
        editingStudentId = null;
        document.getElementById('form_title').innerText = 'Admission';
        document.getElementById('saveBtn').innerText = 'SAVE';
        document.getElementById('cancelBtn').classList.add('hidden');
        ['reg_name','reg_photo','reg_contact'].forEach(id=>document.getElementById(id).value='');
        document.getElementById('reg_fees').value='0';
        document.getElementById('photoPreview').innerHTML='📷';
    };

    function renderRollCall() {
        let html = '';
        students.forEach(s => { html += `<div class="card"><div><b>${s.name}</b><br>${s.class}</div><button class="btn-main" style="background:${s.is_absent?'#d90429':'#2b9348'};width:auto;padding:8px 16px;" onclick="toggleAbsence('${s.id}')">${s.is_absent?'ABSENT':'PRESENT'}</button></div>`; });
        html += `<button class="btn-main" onclick="saveAttendanceHistory()">Save Today's Record</button>`;
        document.getElementById('view-roll').innerHTML = html;
    }
    window.toggleAbsence = async (id) => {
        const s = students.find(x => x.id === id);
        if(s) { await safeUpdate('students',{id},{is_absent:!s.is_absent}); loadAllData(); }
    };
    window.saveAttendanceHistory = async () => {
        const today = new Date().toISOString().slice(0,10);
        for(const s of students) { await safeInsert('attendance',{sch_id:session.schId, student_id:s.id, date:today, status:s.is_absent?'absent':'present'}); }
        alert('Attendance recorded');
    };

    function renderMarksPage() {
        const classes = [...new Set(students.map(s=>s.class))];
        document.getElementById('view-marks').innerHTML = `<div class="form-group"><label>Class</label><select id="marksClassSelect" onchange="loadStudentsForMarks()"><option value="">-- Select --</option>${classes.map(c=>`<option>${c}</option>`).join('')}</select><div id="marksStudentArea"></div></div>`;
    }
    async function loadStudentsForMarks() {
        const cls = document.getElementById('marksClassSelect').value; if(!cls) return;
        const classStudents = students.filter(s=>s.class===cls);
        let yearOpts = ''; for(let y=new Date().getFullYear()-1; y<=new Date().getFullYear()+2; y++) yearOpts += `<option value="${y}">${y}</option>`;
        document.getElementById('marksStudentArea').innerHTML = `<label>Year</label><select id="marksYearSelect">${yearOpts}</select><label>Term</label><select id="marksTermNumberSelect"><option value="1">T1</option><option value="2">T2</option><option value="3">T3</option></select><label>Exam</label><select id="marksExamSelect"><option>Beginning of Term</option><option>Mid Term</option><option selected>End of Term</option></select><label>Student</label><select id="marksStudentSelect" onchange="loadMarksForStudent()"><option value="">-- Select --</option>${classStudents.map(s=>`<option value="${s.id}">${s.name}</option>`).join('')}</select><div id="marksEntryArea"></div>`;
    }
    async function loadMarksForStudent() {
        const studentId = document.getElementById('marksStudentSelect').value;
        const year = document.getElementById('marksYearSelect').value;
        const termNum = document.getElementById('marksTermNumberSelect').value;
        const examType = document.getElementById('marksExamSelect').value;
        if(!studentId) return;
        const termName = `Term ${termNum} ${year}`;
        let term = terms.find(t=>t.name===termName);
        if(!term) {
            await safeInsert('terms',[{sch_id:session.schId, name:termName, year:parseInt(year), term_number:parseInt(termNum), start_date:`${year}-01-01`, end_date:`${year}-12-31`, is_active:true}]);
            terms = await safeFetch('terms',{sch_id:session.schId});
            term = terms.find(t=>t.name===termName);
        }
        const termId = term?.id;
        const existing = marksData.filter(m=>m.student_id===studentId&&m.term_id===termId&&m.exam_type===examType);
        const map = {}; existing.forEach(m=>map[m.subject_id]=m.score);
        let html = `<div class="form-group"><h4>Marks for ${students.find(s=>s.id===studentId)?.name} (${examType})</h4>`;
        subjects.forEach(sub => {
            const score = map[sub.id]||'';
            html += `<div style="display:flex;gap:10px;align-items:center;margin-bottom:8px;"><label style="width:120px;">${sub.name}</label><input type="number" id="mark_${sub.id}" value="${score}" min="0" max="100" onchange="updateGrade('${sub.id}')"><span id="grade_${sub.id}">${score?getGrade(parseFloat(score)):''}</span></div>`;
        });
        html += `<button class="btn-main" onclick="saveMarks('${studentId}','${termId}','${examType}')">Save Marks</button></div>`;
        document.getElementById('marksEntryArea').innerHTML = html;
    }
    window.updateGrade = (subId) => {
        const score = parseFloat(document.getElementById(`mark_${subId}`).value);
        document.getElementById(`grade_${subId}`).textContent = isNaN(score)?'':getGrade(score);
    };
    window.saveMarks = async (studentId, termId, examType) => {
        for (const sub of subjects) {
            const el = document.getElementById(`mark_${sub.id}`);
            if (el && el.value !== '') {
                const score = parseFloat(el.value);
                await safeDelete('marks',{student_id:studentId,term_id:termId,subject_id:sub.id,exam_type:examType});
                await safeInsert('marks',[{sch_id:session.schId,student_id:studentId,term_id:termId,subject_id:sub.id,exam_type:examType,score,grade:getGrade(score)}]);
            }
        }
        const endMarks = marksData.filter(m=>m.student_id===studentId&&m.exam_type==='End of Term');
        const avg = endMarks.length ? endMarks.reduce((a,b)=>a+b.score,0)/endMarks.length : 0;
        const total = endMarks.reduce((a,b)=>a+b.score,0);
        const rc = reportCards.find(r=>r.student_id===studentId&&r.term_id===termId);
        if (rc) await safeUpdate('report_cards',{id:rc.id},{total_score:total,average_score:avg,status:'pending'});
        else await safeInsert('report_cards',[{sch_id:session.schId,student_id:studentId,term_id:termId,total_score:total,average_score:avg,status:'pending'}]);
        alert('Marks saved'); loadAllData(); loadMarksForStudent();
    };

    function renderReportsPage() {
        let html = `<div class="form-group"><h3>Report Cards</h3>`;
        students.forEach(s=>{
            const rc = reportCards.find(r=>r.student_id===s.id);
            const status = rc?rc.status:'pending';
            html += `<div class="card"><div><b>${s.name}</b><br>Avg: ${rc?rc.average_score:'0'}% | <span class="badge badge-${status}">${status}</span></div><div><button class="btn-sm" onclick="viewReport('${s.id}')">View</button>${session.role==='admin'&&status==='pending'?`<button class="btn-sm" onclick="approveReport('${s.id}')">Approve</button>`:''}${session.role==='admin'&&status==='approved'?`<button class="btn-sm" onclick="releaseReport('${s.id}')">Release</button>`:''}</div></div>`;
        });
        html+=`</div>`; document.getElementById('view-reports').innerHTML = html;
    }
    window.approveReport = async (sid)=>{ const rc = reportCards.find(r=>r.student_id===sid); if(rc){ await safeUpdate('report_cards',{id:rc.id},{status:'approved'}); loadAllData(); }};
    window.releaseReport = async (sid)=>{ const rc = reportCards.find(r=>r.student_id===sid); if(rc){ await safeUpdate('report_cards',{id:rc.id},{status:'released'}); loadAllData(); }};
    window.viewReport = (sid)=>{ const s = students.find(st=>st.id===sid); window.open().document.write(`<h2>${session.schoolName}</h2><p>${s.name}</p><button onclick="window.print()">Print</button>`); };

    function renderFees() {
        const totalExp = students.reduce((s,st)=>s+st.total_fees,0);
        const totalCol = students.reduce((s,st)=>s+st.fees_paid,0);
        document.getElementById('view-fees').innerHTML = `<div class="form-group"><h3>Financial Summary</h3><p>Expected: ${formatCurrency(totalExp)}</p><p>Collected: ${formatCurrency(totalCol)}</p><p>Outstanding: ${formatCurrency(totalExp-totalCol)}</p></div><div class="form-group"><h3>Record Payment</h3><label>Student</label><select id="feeStudent">${students.map(s=>`<option value="${s.id}">${s.name} (Debt: ${formatCurrency(s.total_fees-s.fees_paid)})</option>`).join('')}</select><label>Amount</label><input id="feeAmount" type="number"><label>Method</label><select id="feeMethod"><option>cash</option><option>mobile_money</option><option>bank_transfer</option></select><button class="btn-main" onclick="recordPayment()">Record</button></div><div class="form-group"><h3>History</h3><div id="paymentHistory">${feePayments.slice().reverse().map(p=>`<div class="card">${formatCurrency(p.amount)} - ${p.payment_method}</div>`).join('')}</div></div>`;
    }
    window.recordPayment = async ()=>{
        const studentId = document.getElementById('feeStudent').value;
        const amount = parseFloat(document.getElementById('feeAmount').value);
        const method = document.getElementById('feeMethod').value;
        if(!studentId||!amount) return;
        await safeInsert('fee_payments',[{sch_id:session.schId,student_id:studentId,amount,payment_method:method,receipt_number:`RCP-${Date.now()}`}]);
        const s = students.find(st=>st.id===studentId);
        await safeUpdate('students',{id:studentId},{fees_paid:(s.fees_paid||0)+amount});
        loadAllData();
    };

    function renderPromotion() {
        const classes = [...new Set(students.map(s=>s.class))];
        document.getElementById('view-promote').innerHTML = `<div class="form-group"><label>From Class</label><select id="promoteFrom">${classes.map(c=>`<option>${c}</option>`).join('')}</select><button class="btn-main" onclick="runPromotion()">Promote Eligible</button></div>`;
    }
    window.runPromotion = async ()=>{
        const from = document.getElementById('promoteFrom').value;
        const order = ['Baby','Middle','Top','P.1','P.2','P.3','P.4','P.5','P.6','P.7'];
        const idx = order.indexOf(from); if(idx===-1||idx===order.length-1) return;
        const to = order[idx+1]; let count=0;
        for(const s of students.filter(s=>s.class===from)){
            const endMarks = marksData.filter(m=>m.student_id===s.id&&m.exam_type==='End of Term');
            if(endMarks.length && endMarks.reduce((a,b)=>a+b.score,0)/endMarks.length >=45){
                await safeUpdate('students',{id:s.id},{class:to}); count++;
            }
        }
        alert(`${count} students promoted to ${to}`); loadAllData();
    };

    function renderSubjects() {
        document.getElementById('view-subjects').innerHTML = `<div class="form-group"><h3>Subjects</h3><input id="newSubject" placeholder="New subject"><button class="btn-main" onclick="addSubject()">Add</button><div>${subjects.map(s=>`<div class="card">${s.name} <button class="btn-sm btn-del" onclick="deleteSubject('${s.id}')">Del</button></div>`).join('')}</div></div>`;
    }
    window.addSubject = async ()=>{ const name = document.getElementById('newSubject').value.trim(); if(name){ await safeInsert('subjects',[{sch_id:session.schId,name}]); loadAllData(); }};
    window.deleteSubject = async (id)=>{ await safeDelete('subjects',{id}); loadAllData(); };

    function renderIdCards() {
        let html = `<div class="form-group"><h3>Student ID Cards</h3>`;
        students.forEach(s=>{ const vu = new Date(); vu.setFullYear(vu.getFullYear()+1); html += `<div class="card"><div class="student-photo">${s.name.charAt(0)}</div><div><b>${s.name}</b><br>LIN: ${s.lin} | ${s.class}<br>Valid: ${vu.toISOString().slice(0,10)}</div><button class="btn-sm" onclick="printId('${s.id}')">Print</button></div>`; });
        html+=`</div>`; document.getElementById('view-idcards').innerHTML = html;
    }
    window.printId = (sid)=>{ const s = students.find(st=>st.id===sid); window.open().document.write(`<h3>${session.schoolName}</h3><p>${s.name} - ${s.lin}</p><button onclick="window.print()">Print</button>`); };
    window.notifyParent = (sid, ch)=>{ alert(`Notification sent via ${ch} (demo)`); };

    // Clocks
    setInterval(()=>{
        const t = new Date().toLocaleTimeString('en-US',{timeZone:'Africa/Kampala'});
        document.getElementById('clock').textContent = t;
        document.getElementById('ugTimeLogin').textContent = '🕐 ' + t + ' EAT';
    },1000);

    // Init
    window.addEventListener('DOMContentLoaded', async ()=>{
        const saved = sessionStorage.getItem('eudes_sms_session');
        if(saved) { session = JSON.parse(saved); showDashboard(); }
        else { showLoginScreen(); await ensureDemoUsers(); }

        document.getElementById('loginForm').addEventListener('submit', async (e)=>{
            e.preventDefault();
            const email = document.getElementById('email').value.trim().toLowerCase();
            const pass = document.getElementById('password').value;
            const errDiv = document.getElementById('loginError');
            errDiv.classList.remove('show'); errDiv.textContent = '';
            if(!email||!pass){ errDiv.textContent='⚠️ Fill all fields'; errDiv.classList.add('show'); return; }
            const btn = document.getElementById('loginBtn');
            btn.disabled = true; btn.textContent = '⏳'; 
            try{
                session = await login(email, pass);
                sessionStorage.setItem('eudes_sms_session', JSON.stringify(session));
                showDashboard();
            } catch(err){
                errDiv.textContent = err.message; errDiv.classList.add('show');
                btn.disabled = false; btn.textContent = '🚀 LOGIN';
            }
        });
    });
</script>
</body>
</html>
