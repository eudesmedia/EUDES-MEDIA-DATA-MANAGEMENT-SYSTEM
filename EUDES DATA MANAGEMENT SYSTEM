        <div class="stat-card"><span class="stat-val" id="stat_total">0</span><small>TOTAL STUDENTS</small></div>
        <div class="stat-card"><span class="stat-val" id="stat_present" style="color:#2b9348">0</span><small>PRESENT</small></div>
